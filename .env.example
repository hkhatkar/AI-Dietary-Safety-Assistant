# Backend
# LLM generation calls the Anthropic API directly (get a key at console.anthropic.com).
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Embeddings for the RAG layer call AWS Bedrock's Titan model (needs AWS credentials
# configured locally, e.g. via `aws configure` - see infra/README.md).
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Region for Bedrock calls and for the CDK-deployed infra (the Lambda function).
AWS_REGION=eu-west-1

# Your own IAM identity, granted direct data-plane access to the OpenSearch Serverless
# collection so local dev (uvicorn) can query/seed it too - find it with
# `aws sts get-caller-identity`. Optional: falls back to the account root principal if unset.
DEPLOYER_IAM_PRINCIPAL_ARN=

# Menu data lives in DynamoDB, queried via PartiQL (matches the CDK stack's table name).
DYNAMODB_TABLE_NAME=can-i-eat-this-dishes

# Kitchen policy notes live in OpenSearch Serverless (vector/k-NN search). ENDPOINT has no
# sensible default - copy it from the CDK stack's OpenSearchEndpoint output after deploying.
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=kitchen-notes

# Local API
BACKEND_PORT=8000

# Frontend
VITE_API_BASE_URL=http://localhost:8000